{
  "name": "@kubosho/blog-app",
  "version": "10.29.1",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "preview": "NODE_ENV=development dotenvx run -- wrangler dev",
    "build": "NODE_ENV=development dotenvx run -- astro build --mode development",
    "build:stg": "NODE_ENV=development CLOUDFLARE_ENV=staging CLOUDFLARE_HYPERDRIVE_LOCAL_CONNECTION_STRING_HYPERDRIVE=postgres://user:password@127.0.0.1:5432/database dotenvx run -- astro build --mode development",
    "build:prd": "NODE_ENV=production CLOUDFLARE_ENV=production CLOUDFLARE_HYPERDRIVE_LOCAL_CONNECTION_STRING_HYPERDRIVE=postgres://user:password@127.0.0.1:5432/database dotenvx run -- astro build --mode production",
    "dev": "ASTRO_DEV_BACKGROUND=1 NODE_ENV=development dotenvx run -- astro dev --mode development",
    "dev:prd": "ASTRO_DEV_BACKGROUND=1 NODE_ENV=production dotenvx run -- astro dev --mode production",
    "deploy": "dotenvx run -- wrangler deploy --env staging",
    "deploy:prd": "dotenvx run -- wrangler deploy --env production",
    "gen:ogimage": "tsx ./tools/og_image/generateOgImage.ts",
    "gen:types": "astro sync",
    "test": "vitest run",
    "format": "prettier --ignore-path='../.gitignore' --ignore-path='../.prettierignore' --write .",
    "check:astro": "astro check",
    "check:format": "npm run format && git diff --exit-code",
    "check:type": "tsc --noEmit",
    "lint:style": "stylelint '**/*.css'",
    "lint:script": "eslint '**/*.{ts,tsx}'",
    "lint:markup": "markuplint '**/*.astro'",
    "e2e": "playwright test",
    "storybook": "storybook dev -p 6006"
  },
  "dependencies": {
    "@cloudflare/workers-types": "4.20260610.1",
    "@o2project/design-system": "1.5.11",
    "@sentry/astro": "10.61.0",
    "@sentry/cloudflare": "10.61.0",
    "astro": "7.0.3",
    "clsx": "2.1.1",
    "dayjs": "1.11.21",
    "drizzle-orm": "0.45.2",
    "escape-html": "1.0.3",
    "pino": "10.3.1",
    "postgres": "3.4.9",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "remark-breaks": "4.0.0",
    "remark-gfm": "4.0.1",
    "remark-html": "16.0.1",
    "remark-parse": "11.0.0",
    "remark-stringify": "11.0.0",
    "rosetta": "1.1.0",
    "strip-markdown": "6.0.0",
    "swr": "2.4.1",
    "unified": "11.0.5",
    "valibot": "1.3.1"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@astrojs/cloudflare": "14.0.1",
    "@astrojs/mdx": "7.0.0",
    "@astrojs/react": "6.0.0",
    "@astrojs/sitemap": "3.7.3",
    "@dotenvx/dotenvx": "1.71.3",
    "@kubosho/configs": "6.5.36",
    "@playwright/test": "1.60.0",
    "@storybook/addon-docs": "10.4.4",
    "@storybook/addon-onboarding": "10.4.4",
    "@storybook/react-vite": "10.4.4",
    "@testing-library/react": "16.3.2",
    "@types/escape-html": "1.0.4",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "fishery": "2.4.0",
    "front-matter": "4.0.2",
    "jsdom": "29.1.1",
    "msw": "2.14.6",
    "playwright": "1.60.0",
    "sharp": "0.35.2",
    "storybook": "10.4.4",
    "tsx": "4.22.4",
    "vite": "8.0.16",
    "vitest": "4.1.8",
    "wrangler": "4.100.0"
  },
  "optionalDependencies": {
    "@rollup/rollup-darwin-arm64": "4.60.4",
    "@rollup/rollup-linux-x64-gnu": "4.60.4"
  }
}
